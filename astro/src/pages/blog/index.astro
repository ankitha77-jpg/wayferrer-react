---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import BlogListingShell from '../../components/BlogListingShell';

const posts = await getCollection('blog');
const sorted = posts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .map((p) => ({
    slug: p.id,
    title: p.data.title,
    date: p.data.date,
    category: p.data.category,
    image: p.data.image,
    description: p.data.description,
    continent: p.data.continent ?? '',
  }));

const BASE_URL = 'https://wayfarerfootprints.com';
const breadcrumbLD = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: BASE_URL },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${BASE_URL}/blog` },
  ],
};
---

<Layout
  title="Travel Blog"
  description="Real adventures from offbeat destinations, practical travel tips, and everything you need to explore the world's hidden corners."
  canonical="/blog"
  structuredData={[breadcrumbLD]}
>
  <BlogListingShell posts={sorted} client:only="react" />
</Layout>
